<?xml version="1.0" encoding="utf-8" ?>
<nlog xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xmlns="http://www.nlog-project.org/schemas/NLog.xsd" autoReload="true" internalLogFile="${baseDir}\logs\nlog.log"
      internalLogLevel="Warning">
    <variable name="defaultLayout"
              value="${longdate} | ${uppercase:${level:padding=-5}} | ${logger:shortName=true:padding=-40} | ${message} ${exception:format=tostring}"/>
    <variable name="messageOnlyLayout" value="${message} ${exception:format=tostring}"/>   
    <targets>
        <default-wrapper xsi:type="AsyncWrapper">
            <wrapper-target xsi:type="RetryingWrapper"/>
        </default-wrapper>
        <target xsi:type="ColoredConsole" name="console" layout="${var:defaultLayout}"
                useDefaultRowHighlightingRules="false" detectConsoleAvailable="true" detectOutputRedirected="true">
            <highlight-row condition="level == LogLevel.Debug" foregroundColor="DarkGray"/>
            <highlight-row condition="level == LogLevel.Info" foregroundColor="DarkGreen"/>
            <highlight-row condition="level == LogLevel.Warn" foregroundColor="Yellow"/>
            <highlight-row condition="level == LogLevel.Error" foregroundColor="DarkRed"/>
            <highlight-row condition="level == LogLevel.Fatal" foregroundColor="Red" backgroundColor="White"/>
        </target>
        <target xsi:type="File" name="file" fileName="${baseDir}\logs\${shortdate}.log" layout="${var:defaultLayout}"
                archiveEvery="Day" archiveAboveSize="10240" maxArchiveFiles="5"/>        
    </targets>
    <rules>
        <logger name="System.*" finalMinLevel="Warn"/>
        <logger name="Microsoft.Identity*" finalMinLevel="Warn"/>
        <logger name="Microsoft.Hosting*" finalMinLevel="Info"/>
        <logger name="Microsoft.Extensions.Hosting*" finalMinLevel="Info"/>
        <logger name="Microsoft.AspNetCore*" finalMinLevel="Warn"/>
        <logger name="Microsoft.EntityFramework*" finalMinLevel="Warn"/>
        <logger name="Microsoft.Azure*" finalMinLevel="Warn"/>
        <logger name="devdeer*"
                finalMinLevel="${when:when='${environment:ASPNETCORE_ENVIRONMENT}'='Development':inner=Debug:else=Info}"
                writeTo="console,file"/>
        <logger name="KHAN*"
                finalMinLevel="${when:when='${environment:ASPNETCORE_ENVIRONMENT}'='Development':inner=Debug:else=Info}"
                writeTo="console,file"/>
        <logger name="*"
                minlevel="${when:when='${environment:ASPNETCORE_ENVIRONMENT}'='Development':inner=Debug:else=Info}"
                writeTo="console"/>
        <logger name="*"
                minlevel="${when:when='${environment:ASPNETCORE_ENVIRONMENT}'='Development':inner=None:else=Trace}"
                writeTo="file"/>       
    </rules>
</nlog>